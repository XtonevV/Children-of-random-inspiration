{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:display_context",
    "cases": [
      {
        "when": [
          "firstperson_righthand",
          "firstperson_lefthand",
          "thirdperson_righthand",
          "thirdperson_lefthand",
          "head",
          "fixed"
        ],
        "model": {
          "type": "minecraft:select",
          "property": "minecraft:component",
          "component": "minecraft:custom_name",
          "cases": [
            {
              "when": "Havel's Greatshield",
              "model": {
                "type": "minecraft:condition",
                "property": "minecraft:using_item",
                "on_true": {
                  "type": "minecraft:model",
                  "model": "ownpack:item/dsr_havelshield_blocking"
                },
                "on_false": {
                  "type": "minecraft:model",
                  "model": "ownpack:item/dsr_havelshield"
                }
              }
            },
            {
              "when": "Grass Crest Shield",
              "model": {
                "type": "minecraft:condition",
                "property": "minecraft:using_item",
                "on_true": {
                  "type": "minecraft:model",
                  "model": "ownpack:item/dsr_grass_crest_shield_blocking"
                },
                "on_false": {
                  "type": "minecraft:model",
                  "model": "ownpack:item/dsr_grass_crest_shield"
                }
              }
            },
            {
              "when": "Golden Wing Crest Shield",
              "model": {
                "type": "minecraft:condition",
                "property": "minecraft:using_item",
                "on_true": {
                  "type": "minecraft:model",
                  "model": "ownpack:item/ds2_gold_crest_shield_blocking"
                },
                "on_false": {
                  "type": "minecraft:model",
                  "model": "ownpack:item/ds2_gold_crest_shield"
                }
              }
            },
            {
              "when": "Crest Shield",
              "model": {
                "type": "minecraft:condition",
                "property": "minecraft:using_item",
                "on_true": {
                  "type": "minecraft:model",
                  "model": "ownpack:item/dsr_crest_shield_blocking"
                },
                "on_false": {
                  "type": "minecraft:model",
                  "model": "ownpack:item/dsr_crest_shield"
                }
              }
            },
            {
              "when": "Trans Crest Shield",
              "model": {
                "type": "minecraft:condition",
                "property": "minecraft:using_item",
                "on_true": {
                  "type": "minecraft:model",
                  "model": "ownpack:item/dsr_trans_crest_shield_blocking"
                },
                "on_false": {
                  "type": "minecraft:model",
                  "model": "ownpack:item/dsr_trans_crest_shield"
                }
              }
            }
          ],
          "fallback": {
            "type": "minecraft:condition",
            "property": "minecraft:using_item",
            "on_true": {
              "type": "minecraft:model",
              "model": "minecraft:item/shield_blocking"
            },
            "on_false": {
              "type": "minecraft:model",
              "model": "minecraft:item/shield"
            }
          }
        }
      }
    ],
    "fallback": {
      "type": "minecraft:select",
      "property": "minecraft:display_context",
      "cases": [
        {
          "when": [
            "gui",
            "ground",
            "on_shelf",
            "none"
          ],
          "model": {
            "type": "minecraft:select",
            "property": "minecraft:component",
            "component": "minecraft:custom_name",
            "cases": [
              {
                "when": "Havel's Greatshield",
                "model": {
                  "type": "minecraft:model",
                  "model": "ownpack:item/dsr_havelshield_gui"
                }
              },
              {
                "when": "Grass Crest Shield",
                "model": {
                  "type": "minecraft:model",
                  "model": "ownpack:item/dsr_grass_crest_shield_gui"
                }
              },
              {
                "when": "Golden Wing Crest Shield",
                "model": {
                  "type": "minecraft:model",
                  "model": "ownpack:item/ds2_gold_crest_shield_gui"
                }
              },
              {
                "when": "Crest Shield",
                "model": {
                  "type": "minecraft:model",
                  "model": "ownpack:item/dsr_crest_shield_gui"
                }
              },
              {
                "when": "Trans Crest Shield",
                "model": {
                  "type": "minecraft:model",
                  "model": "ownpack:item/dsr_trans_crest_shield_gui"
                }
              }
            ],
            "fallback": {
              "type": "minecraft:model",
              "model": "minecraft:item/shield"
            }
          }
        }
      ]
    }
  }
}