{
  "model": {
    "type": "minecraft:select",
    "property": "minecraft:component",
    "component": "minecraft:custom_name",
    "cases": [
      {
        "when": "Xtonev",
        "model": {
          "type": "minecraft:model",
          "model": "ownpack:item/tou_stan"
        }
      },
      {
        "when": "Fineriso",
        "model": {
          "type": "minecraft:model",
          "model": "ownpack:item/tou_riso"
        }
      },
      {
        "when": "Blahaj",
        "model": {
          "type": "minecraft:model",
          "model": "ownpack:item/tou_blahaj"
        }
      },
      {
        "when": "Blåhaj",
        "model": {
          "type": "minecraft:model",
          "model": "ownpack:item/tou_blahaj"
        }
      }
    ],
    "fallback": {
      "type": "minecraft:model",
      "model": "minecraft:item/totem_of_undying"
    }
  },
  "hand_animation_on_swap": true
}